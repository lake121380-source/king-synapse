  "boundary_operation_contract": {
    "offset_unit": "zero-based Unicode code-point offsets over the exact supplied source_text; end is exclusive",
    "operations": [
      {
        "kind": "reuse_span",
        "required_fields": [
          "kind",
          "reviewer_claim_ids"
        ],
        "rule": "One or more supplied same-anchor Reviewer Claim IDs whose source spans are byte-for-byte identical; the final span is that shared span."
      },
      {
        "kind": "merge_spans",
        "required_fields": [
          "kind",
          "reviewer_claim_ids"
        ],
        "rule": "Two or more supplied same-anchor Reviewer Claim IDs containing at least two distinct spans; the final span is [minimum start, maximum end)."
      },
      {
        "kind": "slice_span",
        "required_fields": [
          "kind",
          "reviewer_claim_ids",
          "relative_start",
          "relative_end"
        ],
        "rule": "One or more supplied same-anchor Reviewer Claim IDs with one identical base span; relative offsets select a non-empty proper subspan within that base span."
      },
      {
        "kind": "new_span",
        "required_fields": [
          "kind",
          "start",
          "end",
          "informed_by_reviewer_claim_ids"
        ],
        "rule": "A non-empty absolute source span used only when reuse, merge, or slice cannot express the decision; informed-by IDs must be supplied from the same anchor."
      }
    ],
    "model_must_not_return": [
      "source_excerpt",
      "occurrence_index",
      "source_span",
      "claim_text"
    ],
    "adapter_derives": [
      "source_span",
      "claim_text",
      "source_occurrence_index",
      "source_reviewer_claim_ids",
      "boundary_operation_kind"
    ],
    "no_excerpt_repair": true,
