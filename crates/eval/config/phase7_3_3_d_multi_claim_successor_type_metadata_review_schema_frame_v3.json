{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "role_codes",
    "type_codes"
  ],
  "properties": {
    "role_codes": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 5
      }
    },
    "type_codes": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 7
      }
    }
  },
  "additionalProperties": false
}
