{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase7.4-atomic-evidence-shadow-overlay-schema-v1",
  "title": "Phase 7.4 Atomic Evidence Shadow Overlay",
  "type": "object",
  "required": [
    "schema_version",
    "overlay_id",
    "status",
    "source_memory_id",
    "source_memory_sha256",
    "source_memory_content_sha256",
    "source_memory_kind",
    "segmentation_contract_version",
    "atomic_units",
    "reconstruction",
    "authority"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "overlay_id": {
      "type": "string",
      "pattern": "^aes-v1-[0-9a-f]{64}$"
    },
    "status": {
      "const": "eval_only_shadow_overlay"
    },
    "source_memory_id": {
      "type": "string",
      "minLength": 1
    },
    "source_memory_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_memory_content_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_memory_kind": {
      "enum": [
        "fact",
        "preference",
        "failure",
        "playbook",
        "state"
      ]
    },
    "segmentation_contract_version": {
      "const": "phase7.4-atomic-evidence-shadow-prototype-v1"
    },
    "atomic_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/atomic_unit"
      }
    },
    "reconstruction": {
      "$ref": "#/$defs/reconstruction"
    },
    "authority": {
      "$ref": "#/$defs/authority"
    }
  },
  "$defs": {
    "atomic_unit": {
      "type": "object",
      "required": [
        "atomic_claim_id",
        "ordinal",
        "claim_text",
        "claim_text_sha256",
        "source_locator",
        "support_state",
        "provenance",
        "confidence",
        "contradiction_links"
      ],
      "properties": {
        "atomic_claim_id": {
          "type": "string",
          "pattern": "^aes-claim-v1-[0-9a-f]{64}$"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "claim_text_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_locator": {
          "oneOf": [
            {
              "$ref": "#/$defs/text_span_locator"
            },
            {
              "$ref": "#/$defs/evidence_locator"
            }
          ]
        },
        "support_state": {
          "enum": [
            "supported",
            "partially_supported",
            "unsupported",
            "not_assessable"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "contradiction_links": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "text_span_locator": {
      "type": "object",
      "required": [
        "locator_type",
        "start_char",
        "end_char"
      ],
      "properties": {
        "locator_type": {
          "const": "source_memory_text_span"
        },
        "start_char": {
          "type": "integer",
          "minimum": 0
        },
        "end_char": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "evidence_locator": {
      "type": "object",
      "required": [
        "locator_type",
        "evidence_id"
      ],
      "properties": {
        "locator_type": {
          "const": "source_evidence_id"
        },
        "evidence_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_memory_id",
        "source_memory_sha256",
        "source_evidence_ids",
        "source_event_ids"
      ],
      "properties": {
        "source_memory_id": {
          "type": "string",
          "minLength": 1
        },
        "source_memory_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_event_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "object",
      "required": [
        "extraction_confidence",
        "support_confidence",
        "calibration_status"
      ],
      "properties": {
        "extraction_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "support_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "calibration_status": {
          "enum": [
            "unvalidated_diagnostic",
            "frozen_calibrated",
            "not_assessable"
          ]
        }
      },
      "additionalProperties": false
    },
    "reconstruction": {
      "type": "object",
      "required": [
        "source_memory_id",
        "ordered_atomic_claim_ids",
        "status",
        "deterministic",
        "overlap_characters",
        "unresolved_gap_count"
      ],
      "properties": {
        "source_memory_id": {
          "type": "string",
          "minLength": 1
        },
        "ordered_atomic_claim_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^aes-claim-v1-[0-9a-f]{64}$"
          }
        },
        "status": {
          "enum": [
            "complete",
            "partial",
            "not_reconstructable"
          ]
        },
        "deterministic": {
          "const": true
        },
        "overlap_characters": {
          "const": 0
        },
        "unresolved_gap_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": [
        "eval_only",
        "runtime_applied",
        "memory_mutated",
        "store_written",
        "recall_engine_mutated",
        "promotion_authorized"
      ],
      "properties": {
        "eval_only": {
          "const": true
        },
        "runtime_applied": {
          "const": false
        },
        "memory_mutated": {
          "const": false
        },
        "store_written": {
          "const": false
        },
        "recall_engine_mutated": {
          "const": false
        },
        "promotion_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "semantic_invariants_not_expressible_in_json_schema": [
    "overlay_id is sha256(phase7.4|source_memory_id|source_memory_sha256|segmentation_contract_version)",
    "atomic_claim_id is sha256(overlay_id|ordinal|claim_text_sha256)",
    "claim_text_sha256 hashes exact UTF-8 claim_text bytes",
    "source_memory_sha256 and provenance source_memory_sha256 are identical",
    "every source locator belongs to the source memory and every provenance evidence ID is frozen input",
    "ordinals are contiguous from zero and reconstruction order equals ordinal order",
    "claim spans do not overlap and all declared reconstruction gaps are explicit",
    "authority fields are constructor-controlled and cannot be promoted by input data"
  ]
}
