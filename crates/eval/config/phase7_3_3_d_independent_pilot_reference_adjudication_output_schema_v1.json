        "rationale"
      ],
      "properties": {
        "operation": {
          "enum": [
            "defer_for_human_review",
            "select_option_1",
            "select_option_2"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
