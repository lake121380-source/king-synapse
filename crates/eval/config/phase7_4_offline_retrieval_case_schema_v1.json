{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase7.4-offline-retrieval-case-schema-v1",
  "title": "Phase 7.4 Offline Retrieval Blind Case",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "stratum",
    "query",
    "query_sha256",
    "candidate_pool_sha256",
    "candidate_memories",
    "phase7_3_3_d_lineage_used"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "case_id": {
      "type": "string",
      "pattern": "^p74-[a-z0-9][a-z0-9_-]{7,95}$"
    },
    "stratum": {
      "enum": [
        "temporal_update",
        "contradiction",
        "preference_evolution",
        "failure_learning",
        "causal_reasoning",
        "multi_entity_reasoning",
        "uncertainty_boundary",
        "adversarial_lexical_overlap"
      ]
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "query_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "candidate_pool_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "candidate_memories": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/candidate_memory"
      }
    },
    "phase7_3_3_d_lineage_used": {
      "const": false
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "candidate_memory": {
      "type": "object",
      "required": [
        "pool_ordinal",
        "source_memory_id",
        "source_memory_kind",
        "source_memory_content",
        "source_memory_content_sha256",
        "source_memory_sha256",
        "source_evidence_ids",
        "source_event_ids",
        "atomic_overlay_id",
        "atomic_overlay_sha256"
      ],
      "properties": {
        "pool_ordinal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "source_memory_id": {
          "type": "string",
          "minLength": 1
        },
        "source_memory_kind": {
          "enum": [
            "fact",
            "preference",
            "failure",
            "playbook",
            "state"
          ]
        },
        "source_memory_content": {
          "type": "string",
          "minLength": 1
        },
        "source_memory_content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "source_memory_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "source_evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_event_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "atomic_overlay_id": {
          "type": "string",
          "pattern": "^aes-v1-[0-9a-f]{64}$"
        },
        "atomic_overlay_sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "semantic_invariants_not_expressible_in_json_schema": [
    "query_sha256 hashes exact UTF-8 query bytes",
    "candidate_pool_sha256 hashes canonical ordered candidate identity and source hashes",
    "pool ordinals are unique and contiguous from zero",
    "source hashes and overlay hashes replay against frozen source and overlay artifacts",
    "Atomic overlays were constructed without query, Gold, or arm-output access",
    "case, source, Candidate, Evidence, and label lineage is independent of Phase 7.3.3-D"
  ]
}
