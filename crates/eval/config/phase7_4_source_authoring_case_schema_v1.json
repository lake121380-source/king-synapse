{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase7.4-source-authoring-case-schema-v1",
  "title": "Phase 7.4 Selected Source Authoring Case",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "stratum",
    "domain",
    "scenario_variant",
    "content_language",
    "query",
    "entities",
    "source_events",
    "source_evidence",
    "candidate_memories",
    "synthetic_content",
    "gold_fields_present",
    "atomic_overlay_present",
    "arm_output_present",
    "phase7_3_3_d_lineage_used",
    "provider_called"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "case_id": {
      "type": "string",
      "pattern": "^p74-(tu|co|pe|fl|cr|me|ub|al)-[0-9]{3}$"
    },
    "stratum": {
      "enum": [
        "temporal_update",
        "contradiction",
        "preference_evolution",
        "failure_learning",
        "causal_reasoning",
        "multi_entity_reasoning",
        "uncertainty_boundary",
        "adversarial_lexical_overlap"
      ]
    },
    "domain": {
      "enum": [
        "software_delivery",
        "data_operations",
        "customer_support",
        "procurement",
        "team_process",
        "research_planning",
        "personal_workflow"
      ]
    },
    "scenario_variant": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "content_language": {
      "const": "en"
    },
    "query": {
      "$ref": "#/$defs/query"
    },
    "entities": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "source_events": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/source_event"
      }
    },
    "source_evidence": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/source_evidence"
      }
    },
    "candidate_memories": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/candidate_memory"
      }
    },
    "synthetic_content": {
      "const": true
    },
    "gold_fields_present": {
      "const": false
    },
    "atomic_overlay_present": {
      "const": false
    },
    "arm_output_present": {
      "const": false
    },
    "phase7_3_3_d_lineage_used": {
      "const": false
    },
    "provider_called": {
      "const": false
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "query": {
      "type": "object",
      "required": [
        "query_id",
        "text",
        "text_sha256"
      ],
      "properties": {
        "query_id": {
          "type": "string",
          "pattern": "^p74-(tu|co|pe|fl|cr|me|ub|al)-[0-9]{3}-query-01$"
        },
        "text": {
          "type": "string",
          "minLength": 20,
          "maxLength": 240
        },
        "text_sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "entity": {
      "type": "object",
      "required": [
        "entity_id",
        "display_name"
      ],
      "properties": {
        "entity_id": {
          "type": "string",
          "pattern": "^p74-(tu|co|pe|fl|cr|me|ub|al)-[0-9]{3}-entity-[0-9]{2}$"
        },
        "display_name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        }
      },
      "additionalProperties": false
    },
    "source_event": {
      "type": "object",
      "required": [
        "source_event_id",
        "logical_time",
        "entity_ids",
        "event_type",
        "description",
        "description_sha256"
      ],
      "properties": {
        "source_event_id": {
          "type": "string",
          "pattern": "^p74-(tu|co|pe|fl|cr|me|ub|al)-[0-9]{3}-event-[0-9]{2}$"
        },
        "logical_time": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "entity_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "event_type": {
          "enum": [
            "observation",
            "statement",
            "decision",
            "action",
            "outcome",
            "revision"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 20,
          "maxLength": 320
        },
        "description_sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "source_evidence": {
      "type": "object",
      "required": [
        "source_evidence_id",
        "source_event_ids",
        "entity_ids",
        "provenance_kind",
        "provenance_locator",
        "observed_text",
        "observed_text_sha256"
      ],
      "properties": {
        "source_evidence_id": {
          "type": "string",
          "pattern": "^p74-(tu|co|pe|fl|cr|me|ub|al)-[0-9]{3}-evidence-[0-9]{2}$"
        },
        "source_event_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "entity_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "provenance_kind": {
          "enum": [
            "synthetic_system_log",
            "synthetic_direct_statement",
            "synthetic_decision_record",
            "synthetic_outcome_record",
            "synthetic_observation",
            "synthetic_unverified_report"
          ]
        },
        "provenance_locator": {
          "type": "string",
          "pattern": "^phase7_4_independent_v1:p74-[a-z0-9-]+$"
        },
        "observed_text": {
          "type": "string",
          "minLength": 20,
          "maxLength": 320
        },
        "observed_text_sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "candidate_memory": {
      "type": "object",
      "required": [
        "memory_authoring_ordinal",
        "pool_ordinal",
        "source_memory_id",
        "source_memory_kind",
        "source_memory_content",
        "source_memory_content_sha256",
        "source_memory_sha256",
        "source_evidence_ids",
        "source_event_ids"
      ],
      "properties": {
        "memory_authoring_ordinal": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "pool_ordinal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "source_memory_id": {
          "type": "string",
          "pattern": "^p74-(tu|co|pe|fl|cr|me|ub|al)-[0-9]{3}-memory-[0-9]{2}$"
        },
        "source_memory_kind": {
          "enum": [
            "fact",
            "preference",
            "failure",
            "playbook",
            "state"
          ]
        },
        "source_memory_content": {
          "type": "string",
          "minLength": 80,
          "maxLength": 640
        },
        "source_memory_content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "source_memory_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "source_evidence_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_event_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "semantic_invariants_not_expressible_in_json_schema": [
    "case identity, stratum, domain, variant, all slot IDs, MemoryKind assignment, and pool ordinal exactly match the frozen authoring plan",
    "all text SHA256 values hash exact UTF-8 bytes without Unicode normalization",
    "source_memory_sha256 hashes the frozen canonical identity-kind-content-evidence-event projection",
    "entity, event, and evidence references resolve within the same case",
    "logical times are unique and exactly cover integers one through six",
    "every source evidence ID is referenced by at least one candidate Memory",
    "no Gold, support, relevance, Atomic overlay, arm output, expected answer, analysis, or author-rationale field is present",
    "all content is synthetic and independent of Phase 7.3.3-D effect data"
  ]
}
