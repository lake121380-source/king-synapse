{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "label_codes",
    "citation_masks",
    "reason_codes",
    "confidence_codes"
  ],
  "properties": {
    "label_codes": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3
      }
    },
    "citation_masks": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "string",
        "pattern": "^[01]{6}$"
      }
    },
    "reason_codes": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 7
      }
    },
    "confidence_codes": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 2
      }
    }
  },
  "additionalProperties": false
}
